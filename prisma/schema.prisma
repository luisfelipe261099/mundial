// Schema do banco — Auto Mecânica Mundial. Postgres (Retool DB / Neon).
// Prisma 7: gerador novo `prisma-client` com output próprio (fora de app/).

generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Client {
  id            String         @id @default(cuid())
  name          String
  cpf           String?
  phone         String?
  whatsapp      String?
  email         String?
  city          String?
  address       String?
  since         String?
  password      String? // hash bcrypt — login do cliente (e-mail ou placa + senha)
  createdAt     DateTime       @default(now())
  vehicles      Vehicle[]
  serviceOrders ServiceOrder[]
  budgets       Budget[]
  appointments  Appointment[]
  documents     Document[]
  notifications Notification[]
  reminders     Reminder[]
  pushSubscriptions PushSubscription[]

  @@map("clients")
}

model Vehicle {
  id               String         @id @default(cuid())
  clientId         String
  client           Client         @relation(fields: [clientId], references: [id], onDelete: Cascade)
  brand            String
  model            String
  year             Int
  version          String?
  color            String?
  plate            String         @unique
  renavam          String?
  chassis          String?
  fuel             String?
  km               Int            @default(0)
  nextRevisionDate String?
  nextRevisionKm   Int?
  revisionOverdue  Boolean        @default(false)
  maintenances     Json?
  lastOilChangeAt  DateTime? // base do lembrete de troca de óleo (por tempo)
  lastRevisaoAt    DateTime? // base do lembrete de revisão (por tempo)
  reminders        Reminder[]
  serviceOrders    ServiceOrder[]

  @@index([clientId])
  @@map("vehicles")
}

model ServiceOrder {
  id           String             @id // ex.: OS-2098
  clientId     String?
  client       Client?            @relation(fields: [clientId], references: [id])
  vehicleId    String?
  vehicle      Vehicle?           @relation(fields: [vehicleId], references: [id])
  clientName   String
  vehicleName  String
  plate        String?
  date         String
  km           Int                @default(0)
  defect       String?
  status       String
  mechanic     String?
  mechanicId   String? // mecânico atribuído (User.id)
  techChecklist Json? // vistoria técnica do mecânico durante a execução
  category     String?
  total        Int                @default(0)
  observations String?
  warranty     String?
  responsible  String?
  photos       Json?
  fuelLevel      String? // combustível na entrada
  exitKm         Int? // km na saída/entrega
  inspection     Json? // vistoria de entrada: { checklist: [{item,status}], avarias, objetos }
  authorized     Boolean            @default(false) // autorização do cliente na entrada
  paid           Boolean            @default(false)
  deliveredAt    String?
  stockApplied   Boolean            @default(false) // baixa de estoque já aplicada?
  financeApplied Boolean            @default(false) // receita já lançada?
  items        ServiceOrderItem[]
  createdAt    DateTime           @default(now())

  @@index([clientId])
  @@index([vehicleId])
  @@index([mechanicId])
  @@map("service_orders")
}

model ServiceOrderItem {
  id             String       @id @default(cuid())
  serviceOrderId String
  serviceOrder   ServiceOrder @relation(fields: [serviceOrderId], references: [id], onDelete: Cascade)
  type           String // Peça | Serviço
  description    String
  qty            Int          @default(1)
  value          Int          @default(0)
  productId      String? // vínculo com o estoque (para baixar ao finalizar)

  @@index([serviceOrderId])
  @@map("service_order_items")
}

model Budget {
  id          String       @id // ex.: ORC-318
  clientId    String?
  client      Client?      @relation(fields: [clientId], references: [id])
  vehicleName String
  date        String
  status      String // pendente | aprovado | rejeitado
  subtotal    Int          @default(0)
  discount    Int          @default(0)
  total          Int          @default(0)
  serviceOrderId String? // orçamento gerado a partir de uma OS
  items          BudgetItem[]

  @@index([clientId])
  @@map("budgets")
}

model BudgetItem {
  id          String @id @default(cuid())
  budgetId    String
  budget      Budget @relation(fields: [budgetId], references: [id], onDelete: Cascade)
  kind        String // peca | servico
  description String
  qty         Int    @default(1)
  value       Int    @default(0)

  @@index([budgetId])
  @@map("budget_items")
}

model Appointment {
  id          String  @id @default(cuid())
  clientId    String?
  client      Client? @relation(fields: [clientId], references: [id])
  clientName  String? // nome livre (agendamento de quem ainda não é cadastrado)
  vehicleName String
  service     String
  date        String
  time        String
  status      String

  @@index([clientId])
  @@map("appointments")
}

model Product {
  id        String          @id @default(cuid())
  name      String
  brand     String?
  code      String          @unique
  qty       Int             @default(0)
  min       Int             @default(0)
  price     Int? // preço de custo em reais inteiros (convenção do sistema)
  movements StockMovement[]

  @@map("products")
}

// Trilha de auditoria: toda entrada/saída de estoque vira um movimento.
model StockMovement {
  id             String   @id @default(cuid())
  productId      String
  product        Product  @relation(fields: [productId], references: [id], onDelete: Restrict)
  delta          Int // + entrada / - saída
  reason         String // "Entrada manual" | "Saída manual" | "Baixa OS" | "Estoque inicial"
  serviceOrderId String? // quando a saída vem de uma OS finalizada
  actor          String? // quem movimentou (nome da sessão)
  createdAt      DateTime @default(now())

  @@index([productId])
  @@map("stock_movements")
}

// Configurações da oficina (linha única, id fixo "default").
model Settings {
  id           String   @id @default("default")
  shopName     String?
  phone        String?
  whatsapp     String?
  address      String?
  notifOleo    Boolean  @default(true)
  notifRevisao Boolean  @default(true)
  notifIpva    Boolean  @default(true)
  notifPromo   Boolean  @default(false)
  updatedAt    DateTime @updatedAt

  @@map("settings")
}

// Lembrete de manutenção gerado pelo motor (dedup por ciclo via @@unique).
model Reminder {
  id        String   @id @default(cuid())
  vehicleId String
  vehicle   Vehicle  @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  clientId  String?
  client    Client?  @relation(fields: [clientId], references: [id])
  type      String // "oleo" | "revisao" | "ipva"
  dueDate   DateTime
  status    String   @default("pendente") // pendente | avisado | concluido | adiado
  createdAt DateTime @default(now())

  @@unique([vehicleId, type, dueDate])
  @@index([clientId])
  @@map("reminders")
}

// Inscrição de Web Push (PWA) de um cliente.
model PushSubscription {
  id        String   @id @default(cuid())
  clientId  String
  client    Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())

  @@index([clientId])
  @@map("push_subscriptions")
}

model Notification {
  id       String  @id @default(cuid())
  clientId String?
  client   Client? @relation(fields: [clientId], references: [id])
  type     String
  title    String
  text     String?
  when     String?
  read     Boolean @default(false)

  @@index([clientId])
  @@map("notifications")
}

model Document {
  id       String  @id @default(cuid())
  clientId String?
  client   Client? @relation(fields: [clientId], references: [id])
  name     String
  type     String
  date     String?

  @@map("documents")
}

model Transaction {
  id          String   @id @default(cuid())
  type           String // receita | despesa
  description    String
  category       String?
  value          Int      @default(0)
  date           String?
  serviceOrderId String? // receita originada de uma OS finalizada
  createdAt      DateTime @default(now())

  @@map("transactions")
}

model Service {
  id       String  @id @default(cuid())
  name     String
  category String?

  @@map("services")
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  role      String   @default("admin") // admin | mecanico | cliente
  password  String? // placeholder até o login/auth ser implementado
  createdAt DateTime @default(now())

  @@map("users")
}
